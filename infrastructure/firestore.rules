rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /missions/{missionId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        // Verify schema validation boundaries for high-security constraints on create
        allow create: if request.auth != null 
                      && request.auth.uid == userId
                      && request.resource.data.title is string 
                      && request.resource.data.title.size() > 0 
                      && request.resource.data.title.size() < 256
                      && request.resource.data.goal is string 
                      && request.resource.data.goal.size() > 0;
      }

      match /missions/{missionId}/files/{fileId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        // Verify file metadata constraints on create
        allow create: if request.auth != null 
                      && request.auth.uid == userId
                      && request.resource.data.size is int
                      && request.resource.data.size < 52428800 // 50MB
                      && request.resource.data.mimeType is string;
      }

      match /missions/{missionId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
