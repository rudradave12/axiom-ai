rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /missions/{missionId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        
        allow create, update: if request.auth != null 
                              && request.auth.uid == userId
                              && request.resource.data.keys().hasAll(['title', 'goal'])
                              && request.resource.data.title is string
                              && request.resource.data.title.size() > 0
                              && request.resource.data.title.size() <= 100
                              && request.resource.data.goal is string;
      }

      match /missions/{missionId}/tasks/{taskId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null 
                              && request.auth.uid == userId
                              && request.resource.data.title is string
                              && request.resource.data.status in ['todo', 'in-progress', 'done', 'skipped', 'blocked'];
      }

      match /missions/{missionId}/timeline/{timelineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /missions/{missionId}/chat/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /missions/{missionId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
